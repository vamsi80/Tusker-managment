# Enforce exact pnpm version from packageManager field — requires Corepack.
# Run once per machine: corepack enable

# Consistent peer dependency resolution across all machines
auto-install-peers=true
strict-peer-dependencies=false

# Prevent accidental lockfile changes — install will fail if lockfile is out of date
# Override locally with: pnpm install --no-frozen-lockfile
frozen-lockfile=false
