model ProjectMaterialItem {
  id                     String           @id @default(uuid())
  projectId              String
  subtaskId              String?          // Nullable to allow SetNull on task deletion
  subtaskNameSnapshot    String?
  parentTaskNameSnapshot String?
  materialName           String
  unit                   String
  quantity               Float
  notes                  String?
  addedById              String
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subtask   Task?           @relation(fields: [subtaskId], references: [id], onDelete: SetNull)
  addedBy   WorkspaceMember @relation(fields: [addedById], references: [id])

  @@index([projectId])
  @@index([subtaskId])
  @@index([materialName])
  @@map("project_material_item")
}
