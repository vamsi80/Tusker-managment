generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String              @id
  name                String
  email               String              @unique
  emailVerified       Boolean             @default(false)
  image               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @default(now()) @updatedAt
  role                String?
  banned              Boolean?            @default(false)
  banReason           String?
  banExpires          DateTime?
  surname             String
  phoneNumber         String?             @unique
  phoneNumberVerified Boolean             @default(false)
  pushToken           String?
  lastActiveAt        DateTime?           @default(now())
  activities          Activity[]
  workspaceOwner      Workspace[]
  workspaces          WorkspaceMember[]
  UserConversations   UserConversations[]
  accounts            Account[]
  activityReads       ActivityRead[]
  auditLogs           AuditLog[]
  comments            Comment[]
  commentReads        CommentRead[]
  dailyReports        DailyReport[]
  direct_message      direct_message[]
  notification        notification[]
  sessions            Session[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Workspace {
  id                     String                     @id @default(uuid())
  name                   String
  slug                   String                     @unique
  description            String?
  ownerId                String
  createdAt              DateTime                   @default(now())
  image_url              String                     @default("")
  updatedAt              DateTime                   @updatedAt
  inviteCode             String                     @unique
  addressLine1           String?
  addressLine2           String?
  city                   String?
  companyType            String?
  country                String?
  email                  String?
  gstNumber              String?
  industry               String?
  legalName              String?
  msmeNumber             String?
  panNumber              String?
  phone                  String?
  pincode                String?
  state                  String?
  website                String?
  lateThreshold          String                     @default("21:30")
  overtimeThreshold      String                     @default("07:00")
  halfDayThreshold       String                     @default("23:00")
  shiftEndTime           String                     @default("07:00")
  shiftStartTime         String                     @default("21:30")
  sickLeaveLimit         Int                        @default(12)
  casualLeaveAccrualDays Int                        @default(20)
  clints                 Clints[]
  projects               Project[]
  tags                   Tag[]
  owner                  User                       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members                WorkspaceMember[]
  attendance             attendance[]
  attendanceLocations    AttendanceLocation[]
  auditLogs              AuditLog[]
  boardItems             Board[]
  conversation           conversation[]
  dailyReports           DailyReport[]
  indents                Indent[]
  leaveRequests          leave_request[]
  materialCatalog        MaterialCatalog[]
  notifications          notification[]
  publicHolidays         public_holiday[]
  units                  UnitOfMeasure[]
  vendors                Vendor[]
  vendorCapabilities     VendorMaterialCapability[]
}

model WorkspaceMember {
  id                     String            @id @default(uuid())
  userId                 String
  workspaceId            String
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  workspaceRole          WorkspaceRole     @default(MEMBER)
  designation            String?
  reportToId             String?
  accruedDaysCount       Int               @default(0)
  casualLeaveBalance     Float             @default(0)
  sickLeaveBalance       Float             @default(12)
  position               Int               @default(0)
  dateOfBirth            DateTime?
  employeeId             String?
  managedProjects        Project[]         @relation("ProjectManager")
  projectMembers         ProjectMember[]
  reportTo               WorkspaceMember?  @relation("ReportTo", fields: [reportToId], references: [id])
  subordinates           WorkspaceMember[] @relation("ReportTo")
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace              Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  attendance             attendance[]
  assignedBoardItems     Board[]           @relation("BoardAssigner")
  boardItems             Board[]           @relation("BoardMember")
  indentsAssigned        Indent[]          @relation("IndentAssignee")
  indentsApproved        Indent[]          @relation("IndentFinalApprover")
  indentsRequested       Indent[]          @relation("IndentRequester")
  processedLeaveRequests leave_request[]   @relation("LeaveProcessor")
  leaveRequests          leave_request[]
  memberTodos            MemberTodo[]
  quotesReviewed         VendorQuote[]     @relation("QuoteReviewer")
  addedMaterialItems     ProjectMaterialItem[]

  @@unique([userId, workspaceId])
  @@index([workspaceId, workspaceRole])
  @@index([userId, createdAt(sort: Desc)])
  @@index([workspaceId, userId])
  @@index([workspaceRole])
  @@index([userId])
  @@index([workspaceId, position, createdAt(sort: Desc)])
}

model Project {
  id               String           @id @default(uuid())
  name             String
  description      String?
  workspaceId      String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  slug             String           @unique
  color            String
  createdBy        String?
  projectManagerId String?
  clintId          String?
  legacyClints     Clints[]         @relation("LegacyProjectClints")
  clint            Clints?          @relation(fields: [clintId], references: [id])
  projectManager   WorkspaceMember? @relation("ProjectManager", fields: [projectManagerId], references: [id])
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectMembers   ProjectMember[]
  tasks            Task[]
  indents          Indent[]
  materialItems    ProjectMaterialItem[]
  tags             Tag[]            @relation("ProjectTags")

  @@index([workspaceId, slug])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, createdBy])
}

model ProjectMember {
  id                String          @id @default(uuid())
  projectId         String
  createdAt         DateTime        @default(now())
  hasAccess         Boolean         @default(false)
  projectRole       ProjectRole     @default(MEMBER)
  updatedAt         DateTime        @updatedAt
  workspaceMemberId String
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspaceMember   WorkspaceMember @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)
  assignedTasks     Task[]          @relation("TaskAssignee")
  createdTasks      Task[]          @relation("TaskCreator")
  reviewingTasks    Task[]          @relation("TaskReviewer")

  @@unique([workspaceMemberId, projectId])
  @@index([projectId, projectRole])
  @@index([workspaceMemberId])
  @@index([projectId, workspaceMemberId])
}

model Clints {
  id                    String         @id @default(uuid())
  name                  String?
  registeredCompanyName String?
  gstNumber             String?
  directorName          String?
  address               String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  projectId             String?
  workspaceId           String?
  clintMembers          ClintMembers[]
  legacyProject         Project?       @relation("LegacyProjectClints", fields: [projectId], references: [id])
  workspace             Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects              Project[]

  @@index([workspaceId])
}

model ClintMembers {
  id          String   @id @default(uuid())
  name        String?
  email       String?
  clintId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  phoneNumber String?
  clints      Clints?  @relation(fields: [clintId], references: [id], onDelete: Cascade)

  @@index([clintId])
}

model Tag {
  id              String    @id @default(uuid())
  name            String
  workspaceId     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  requirePurchase Boolean?  @default(false)
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks           Task[]    @relation("TaskTags")
  projects        Project[] @relation("ProjectTags")

  @@unique([workspaceId, name])
}

model Task {
  id                    String             @id @default(uuid())
  projectId             String
  description           String?
  status                TaskStatus?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  createdById           String
  days                  Int?
  name                  String
  parentTaskId          String?
  startDate             DateTime?
  taskSlug              String             @unique
  assigneeId            String?
  completedSubtaskCount Int                @default(0)
  dueDate               DateTime?
  isParent              Boolean            @default(true)
  path                  String?
  reviewerId            String?
  subtaskCount          Int                @default(0)
  workspaceId           String
  position              Int                @default(0)
  activities            Activity[]
  assignee              ProjectMember?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy             ProjectMember      @relation("TaskCreator", fields: [createdById], references: [id])
  parentTask            Task?              @relation("Task_subTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks              Task[]             @relation("Task_subTasks")
  project               Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewer              ProjectMember?     @relation("TaskReviewer", fields: [reviewerId], references: [id])
  comments              Comment[]
  dailyReportEntries    DailyReportEntry[]
  indent                Indent?
  Task_TaskDependency_A Task[]             @relation("TaskDependency")
  Task_TaskDependency_B Task[]             @relation("TaskDependency")
  tags                  Tag[]              @relation("TaskTags")
  materialItems         ProjectMaterialItem[]

  @@index([projectId, status, isParent, createdAt(sort: Desc)])
  @@index([workspaceId, status, isParent])
  @@index([workspaceId, projectId, status, isParent, dueDate, createdAt(sort: Desc)])
  @@index([parentTaskId, createdAt])
  @@index([workspaceId, parentTaskId, status, isParent, createdAt(sort: Desc)])
  @@index([workspaceId, assigneeId, status, createdAt])
  @@index([projectId, assigneeId, status, createdAt])
  @@index([name, id])
  @@index([startDate, id])
  @@index([dueDate, id])
  @@index([createdAt(sort: Desc), id])
  @@index([workspaceId, assigneeId, updatedAt(sort: Desc)])
}

model Activity {
  id          String         @id @default(uuid())
  subTaskId   String
  authorId    String
  text        String
  attachment  Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workspaceId String
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  subTask     Task           @relation(fields: [subTaskId], references: [id], onDelete: Cascade)
  readBy      ActivityRead[]

  @@index([subTaskId, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([workspaceId])
}

model ActivityRead {
  id         String   @id @default(uuid())
  userId     String
  activityId String
  createdAt  DateTime @default(now())
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@index([userId])
  @@index([activityId])
  @@map("activity_read")
}

model Comment {
  id              String        @id @default(uuid())
  content         String
  userId          String
  taskId          String
  parentCommentId String?
  isEdited        Boolean       @default(false)
  editedAt        DateTime?
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  parentComment   Comment?      @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         Comment[]     @relation("CommentReplies")
  task            Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  readBy          CommentRead[]

  @@index([taskId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([parentCommentId])
  @@index([createdAt])
  @@map("comment")
}

model CommentRead {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([userId])
  @@index([commentId])
  @@map("comment_read")
}

model DailyReport {
  id              String             @id @default(uuid())
  workspaceId     String
  userId          String
  date            DateTime           @db.Date
  status          ReportStatus
  submittedAt     DateTime?
  isAutoGenerated Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  entries         DailyReportEntry[]
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId, date])
  @@index([workspaceId, date])
  @@map("daily_reports")
}

model DailyReportEntry {
  id          String          @id @default(uuid())
  reportId    String
  taskId      String?
  type        ReportEntryType
  description String?
  createdAt   DateTime        @default(now())
  report      DailyReport     @relation(fields: [reportId], references: [id], onDelete: Cascade)
  task        Task?           @relation(fields: [taskId], references: [id])

  @@index([reportId])
  @@index([taskId])
  @@map("daily_report_entries")
}

model attendance {
  id                String           @id
  workspaceId       String
  workspaceMemberId String
  date              DateTime         @db.Date
  checkIn           DateTime?
  checkOut          DateTime?
  checkInLatitude   Float?
  checkInLongitude  Float?
  checkOutLatitude  Float?
  checkOutLongitude Float?
  status            AttendanceStatus @default(PRESENT)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime
  checkInAddress    String?
  checkOutAddress   String?
  isOvertime        Boolean          @default(false)
  lateThreshold     String?
  overtimeThreshold String?
  checkInNotes      String?
  checkOutNotes     String?
  Workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  WorkspaceMember   WorkspaceMember  @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)

  @@unique([workspaceMemberId, date])
  @@index([workspaceId, date])
}

model AttendanceLocation {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  address     String?
  latitude    Float
  longitude   Float
  radius      Float     @default(100)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  Workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("attendance_locations")
}

model Board {
  id           String          @id @default(uuid())
  workspaceId  String
  memberId     String
  assignedById String
  note         String
  status       BoardStatus     @default(NOT_DONE)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  assignedBy   WorkspaceMember @relation("BoardAssigner", fields: [assignedById], references: [id], onDelete: Cascade)
  member       WorkspaceMember @relation("BoardMember", fields: [memberId], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([memberId])
  @@index([assignedById])
  @@map("board_items")
}

model AuditLog {
  id          String     @id @default(uuid())
  workspaceId String?
  userId      String
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
  @@index([workspaceId, createdAt])
  @@map("audit_log")
}

model conversation {
  id                String              @id @default(uuid())
  workspaceId       String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @default(now()) @updatedAt
  lastMessageAt     DateTime?           @default(now())
  type              String              @default("direct")
  UserConversations UserConversations[]
  Workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  direct_message    direct_message[]

  @@index([workspaceId])
  @@index([lastMessageAt])
}

model direct_message {
  id             String       @id @default(uuid())
  content        String
  createdAt      DateTime     @default(now())
  senderId       String
  conversationId String
  isDeleted      Boolean      @default(false)
  isRead         Boolean      @default(false)
  updatedAt      DateTime     @default(now()) @updatedAt
  conversation   conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model notification {
  id          String    @id
  userId      String
  workspaceId String
  title       String
  body        String
  type        String
  isRead      Boolean   @default(false)
  entityId    String?
  entityType  String?
  eventId     String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([createdAt])
  @@index([userId, workspaceId])
  @@index([userId, workspaceId, isRead])
}

// Transactional outbox: realtime events to publish to tusker-ws. Written in the same
// transaction as the audit + notification rows, then published via ctx.waitUntil and
// re-published by the cron sweeper if the first attempt fails — at-least-once delivery.
model Outbox {
  id            String    @id @default(uuid())
  workspaceId   String
  event         String
  payload       Json
  targetUserIds String[]
  publishedAt   DateTime?
  attempts      Int       @default(0)
  createdAt     DateTime  @default(now())

  @@index([publishedAt, createdAt])
  @@map("outbox")
}

model leave_request {
  id                String           @id @default(uuid())
  workspaceId       String
  workspaceMemberId String
  startDate         DateTime         @db.Date
  endDate           DateTime         @db.Date
  reason            String
  status            LeaveStatus      @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  type              LeaveType        @default(CASUAL)
  processedById     String?
  processedBy       WorkspaceMember? @relation("LeaveProcessor", fields: [processedById], references: [id])
  Workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  WorkspaceMember   WorkspaceMember  @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceMemberId])
}

model public_holiday {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  date        DateTime  @db.Date
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, date])
}

model UserConversations {
  A            String
  B            String
  user         User         @relation(fields: [A], references: [id], onDelete: Cascade)
  conversation conversation @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_UserConversations_AB_pkey")
  @@index([B], map: "_UserConversations_B_index")
  @@map("_UserConversations")
}

model MemberTodo {
  id          String          @id @default(uuid())
  memberId    String
  text        String
  completed   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  completedAt DateTime?
  updatedAt   DateTime        @updatedAt
  position    Int             @default(0)
  member      WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("member_todos")
}

model VendorMaterialCapability {
  id           String                @id @default(cuid())
  vendorId     String
  materialName String
  unit         String?
  workspaceId  String
  source       String                @default("MANUAL")
  createdAt    DateTime              @default(now())
  serviceType  CapabilityServiceType @default(SUPPLY)
  vendor       Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  workspace    Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([vendorId, materialName, serviceType])
  @@index([workspaceId, materialName])
  @@map("vendor_material_capability")
}

model MaterialCatalog {
  id            String         @id @default(cuid())
  workspaceId   String
  name          String
  unit          String?
  source        String         @default("INDENT")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  defaultUnitId String?
  defaultUnit   UnitOfMeasure? @relation(fields: [defaultUnitId], references: [id])
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("material_catalog")
}

model UnitOfMeasure {
  id           String            @id @default(cuid())
  workspaceId  String
  name         String
  abbreviation String
  category     String?
  isDefault    Boolean           @default(false)
  createdAt    DateTime          @default(now())
  materials    MaterialCatalog[]
  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, abbreviation])
  @@index([workspaceId])
  @@map("unit_of_measure")
}

model Indent {
  id                String           @id @default(uuid())
  indentId          String?          @unique
  workspaceId       String
  projectId         String
  taskId            String?          @unique
  name              String
  description       String?
  status            IndentStatus     @default(DRAFT)
  expectedDelivery  DateTime?
  requestedById     String
  assignedToId      String?
  submittedAt       DateTime?
  finalApprovedAt   DateTime?
  finalApprovedById String?
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  assignedTo        WorkspaceMember? @relation("IndentAssignee", fields: [assignedToId], references: [id])
  finalApprovedBy   WorkspaceMember? @relation("IndentFinalApprover", fields: [finalApprovedById], references: [id])
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy       WorkspaceMember  @relation("IndentRequester", fields: [requestedById], references: [id])
  task              Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lineItems         IndentLineItem[]

  @@index([workspaceId, status])
  @@index([projectId, status])
  @@index([taskId])
  @@index([requestedById])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("indent")
}

model IndentLineItem {
  id                 String         @id @default(uuid())
  indentId           String
  materialName       String
  description        String?
  unit               String
  quantity           Int
  estimatedUnitPrice Int?
  specifications     String?
  status             LineItemStatus @default(PENDING)
  rfqSentAt          DateTime?
  rfqDeadline        DateTime?
  approvedQuoteId    String?
  rejectionReason    String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  approvedQuote      VendorQuote?   @relation("ApprovedQuote", fields: [approvedQuoteId], references: [id])
  indent             Indent         @relation(fields: [indentId], references: [id], onDelete: Cascade)
  vendorQuotes       VendorQuote[]

  @@index([indentId])
  @@index([status])
  @@index([materialName])
  @@map("indent_line_item")
}

model Vendor {
  id            String                     @id @default(uuid())
  name          String
  companyName   String?
  contactPerson String?
  email         String?
  address       String?
  gstNumber     String?
  workspaceId   String
  isActive      Boolean                    @default(true)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  phoneNumber   String?
  status        VendorStatus               @default(ACTIVE)
  addressLine1  String?
  addressLine2  String?
  city          String?
  country       String?                    @default("India")
  pincode       String?
  state         String?
  workspace     Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  capabilities  VendorMaterialCapability[]
  quotes        VendorQuote[]

  @@index([workspaceId])
  @@index([name])
  @@map("vendor")
}

model VendorQuote {
  id                   String           @id @default(uuid())
  lineItemId           String
  vendorId             String
  unitPrice            Decimal          @db.Decimal(15, 2)
  quantity             Decimal          @db.Decimal(15, 3)
  totalPrice           Decimal          @db.Decimal(15, 2)
  currency             String           @default("INR")
  leadTimeDays         Int?
  validUntil           DateTime?
  notes                String?
  attachmentUrl        String?
  status               QuoteStatus      @default(SUBMITTED)
  submittedAt          DateTime         @default(now())
  reviewedAt           DateTime?
  reviewedById         String?
  rejectionReason      String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  approvedForLineItems IndentLineItem[] @relation("ApprovedQuote")
  lineItem             IndentLineItem   @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  reviewedBy           WorkspaceMember? @relation("QuoteReviewer", fields: [reviewedById], references: [id])
  vendor               Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([lineItemId, vendorId])
  @@index([lineItemId])
  @@index([vendorId])
  @@index([status])
  @@map("vendor_quote")
}

