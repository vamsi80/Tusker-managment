generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  // Disable prepared statements when using connection poolers
  // Add ?pgbouncer=true to your DATABASE_URL if using PgBouncer/Supabase Pooler
}

model User {
  id             String            @id
  name           String
  surname        String?
  contactNumber  String?
  email          String            @unique
  emailVerified  Boolean           @default(false)
  image          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @default(now()) @updatedAt
  role           String?
  banned         Boolean?          @default(false)
  banReason      String?
  banExpires     DateTime?
  workspaceOwner Workspace[]
  workspaces     WorkspaceMember[]
  accounts       Account[]
  auditLogs      AuditLog[]
  comments       Comment[]
  sessions       Session[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Workspace {
  id               String            @id @default(uuid())
  name             String
  description      String?
  slug             String            @unique
  ownerId          String
  inviteCode       String            @unique
  image_url        String            @default("")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  projects         Project[]
  procurementTasks ProcurementTask[]
  tags             Tag[]
  owner            User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members          WorkspaceMember[]
  materials        Material[]
  units            Unit[]
  vendors          Vendor[]
}

model WorkspaceMember {
  id             String          @id @default(uuid())
  userId         String
  workspaceId    String
  workspaceRole  WorkspaceRole   @default(MEMBER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  projectMembers ProjectMember[]
  reviewComments ReviewComment[]
  tasks          Task[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  auditLogs      AuditLog[]
  units          Unit[]

  @@unique([userId, workspaceId])
  @@index([workspaceId, workspaceRole])
  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, userId])
  @@index([workspaceRole])
}

model Project {
  id               String            @id @default(uuid())
  name             String
  description      String?
  slug             String            @unique
  workspaceId      String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  clint            Clints[]
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectMembers   ProjectMember[]
  tasks            Task[]
  procurementTasks ProcurementTask[]
  indentDetails    IndentDetails[]
  auditLogs        AuditLog[]

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([slug])
}

model ProjectMember {
  id                String          @id @default(uuid())
  projectRole       ProjectRole     @default(MEMBER)
  projectId         String
  workspaceMemberId String
  hasAccess         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspaceMember   WorkspaceMember @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)
  tasks             Task[]

  @@unique([workspaceMemberId, projectId])
  @@index([projectId, projectRole])
  @@index([projectId])
  @@index([workspaceMemberId])
  @@index([projectId, workspaceMemberId])
}

model Clints {
  id                    String         @id @default(uuid())
  name                  String
  registeredCompanyName String?
  gstNumber             String?
  directorName          String?
  address               String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  projectId             String?
  clintMembers          ClintMembers[]
  project               Project?       @relation(fields: [projectId], references: [id])
}

model ClintMembers {
  id            String   @id @default(uuid())
  name          String
  email         String?
  contactNumber String?
  clintId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  clints        Clints?  @relation(fields: [clintId], references: [id], onDelete: Cascade)
}

model Tag {
  id              String    @id @default(uuid())
  name            String
  requirePurchase Boolean?  @default(false)
  workspaceId     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks           Task[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Task {
  id                    String           @id @default(uuid())
  name                  String
  taskSlug              String           @unique
  description           String?
  status                TaskStatus?      @default(TO_DO)
  position              Int?
  parentTaskId          String?
  startDate             DateTime?
  days                  Int?
  tagId                 String?
  assigneeTo            String?
  createdById           String
  projectId             String
  purchaseRequired      Boolean?         @default(false)
  isPinned              Boolean          @default(false)
  pinnedAt              DateTime?
  pinnedBy              String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  reviewComments        ReviewComment[]
  tag                   Tag?             @relation(fields: [tagId], references: [id], onDelete: SetNull)
  assignee              ProjectMember?   @relation(fields: [assigneeTo], references: [id], onDelete: Cascade)
  createdBy             WorkspaceMember  @relation(fields: [createdById], references: [id], onDelete: Cascade)
  parentTask            Task?            @relation("Task_subTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks              Task[]           @relation("Task_subTasks")
  project               Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  auditLogs             AuditLog[]
  comments              Comment[]
  Task_TaskDependency_A Task[]           @relation("TaskDependency")
  Task_TaskDependency_B Task[]           @relation("TaskDependency")
  procurementTask       ProcurementTask?
  indentDetails         IndentDetails[]

  @@index([parentTaskId])
  @@index([projectId])
  @@index([projectId, parentTaskId])
  @@index([projectId, status])
  @@index([status, createdAt])
  @@index([createdById])
  @@index([assigneeTo])
  @@index([isPinned])
  @@index([position])
  @@index([tagId])
}

model ReviewComment {
  id         String          @id @default(uuid())
  subTaskId  String
  authorId   String
  text       String
  attachment Json?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  author     WorkspaceMember @relation(fields: [authorId], references: [id], onDelete: Cascade)
  subTask    Task            @relation(fields: [subTaskId], references: [id], onDelete: Cascade)

  @@index([subTaskId, createdAt])
}

model Comment {
  id              String    @id @default(uuid())
  content         String
  userId          String
  taskId          String
  parentCommentId String?
  isEdited        Boolean   @default(false)
  editedAt        DateTime?
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  parentComment   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         Comment[] @relation("CommentReplies")
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([parentCommentId])
  @@index([createdAt])
  @@map("comment")
}

model AuditLog {
  id                String          @id @default(cuid())
  operationId       String          @unique
  entityType        String
  entityId          String
  action            String
  userId            String
  workspaceMemberId String
  beforeState       Json?
  afterState        Json
  projectId         String
  taskId            String?
  timestamp         DateTime        @default(now())
  ipAddress         String?
  userAgent         String?
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task              Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceMember   WorkspaceMember @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([entityType])
  @@index([action])
  @@index([projectId])
  @@index([userId])
  @@index([timestamp])
  @@index([operationId])
  @@map("audit_log")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectRole {
  LEAD
  MEMBER
  VIEWER
}

enum TaskStatus {
  TO_DO
  IN_PROGRESS
  BLOCKED
  REVIEW
  HOLD
  COMPLETED
}

model ProcurementTask {
  id            String   @id @default(uuid())
  taskId        String   @unique
  projectId     String
  workspaceId   String
  indentCreated Boolean  @default(false)
  createdAt     DateTime @default(now())

  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
  @@map("procurement_task")
}

enum IndentStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

// Member-created indent request (role-safe)
model IndentDetails {
  id               String       @id @default(uuid())
  key              String       @unique // e.g., IND-001
  name             String // Indent title/name
  projectId        String
  taskId           String? // Optional task reference
  description      String? // Request description
  expectedDelivery DateTime? // Expected delivery date
  requiresVendor   Boolean      @default(true) // Whether vendor quotation is required
  requestedBy      String // User ID who created the request
  status           IndentStatus @default(REQUESTED)
  requestedAt      DateTime     @default(now()) // When request was created
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  project       Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task          Task?                 @relation(fields: [taskId], references: [id], onDelete: SetNull)
  items         IndentItem[]
  decision      IndentDecision? // 1:1 relationship, only exists when approved
  statusHistory IndentStatusHistory[]

  @@index([projectId])
  @@index([taskId])
  @@index([requestedBy])
  @@index([status])
  @@index([key])
  @@map("indent_details")
}

model IndentItem {
  id              String   @id @default(uuid())
  indentDetailsId String
  materialId      String
  quantity        Float
  unitId          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  indentDetails IndentDetails @relation(fields: [indentDetailsId], references: [id], onDelete: Cascade)
  material      Material      @relation(fields: [materialId], references: [id], onDelete: Restrict)
  unit          Unit?         @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([indentDetailsId])
  @@index([materialId])
  @@map("indent_item")
}

// Admin/Owner procurement decisions (restricted access)
model IndentDecision {
  id              String   @id @default(uuid())
  indentDetailsId String   @unique // 1:1 with IndentDetails
  requiresVendor  Boolean  @default(true) // true = vendor required, false = direct PO
  approvedBy      String // User ID of admin/owner
  approvedAt      DateTime @default(now())
  notes           String? // Admin notes/remarks
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  indentDetails IndentDetails        @relation(fields: [indentDetailsId], references: [id], onDelete: Cascade)
  items         IndentDecisionItem[] // Multiple materials can be approved
  material      Material?            @relation(fields: [materialId], references: [id])
  materialId    String?

  @@index([indentDetailsId])
  @@index([approvedBy])
  @@index([requiresVendor])
  @@map("indent_decision")
}

// Individual material items in an indent decision
model IndentDecisionItem {
  id               String   @id @default(uuid())
  indentDecisionId String
  materialId       String
  approvedQuantity Float // Approved quantity for this material
  unitId           String? // Unit of measure
  estimatedCost    Float? // Estimated cost per unit
  specifications   String? // Specific requirements for this material
  remarks          String? // Item-specific notes
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  indentDecision IndentDecision @relation(fields: [indentDecisionId], references: [id], onDelete: Cascade)
  material       Material       @relation(fields: [materialId], references: [id], onDelete: Restrict)
  unit           Unit?          @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([indentDecisionId])
  @@index([materialId])
  @@index([unitId])
  @@map("indent_decision_item")
}

// Audit trail for status transitions
model IndentStatusHistory {
  id              String        @id @default(uuid())
  indentDetailsId String
  fromStatus      IndentStatus? // Null for initial creation
  toStatus        IndentStatus
  changedBy       String // User ID who made the change
  changedAt       DateTime      @default(now())
  remarks         String? // Reason for status change

  indentDetails IndentDetails @relation(fields: [indentDetailsId], references: [id], onDelete: Cascade)

  @@index([indentDetailsId])
  @@index([changedAt])
  @@index([changedBy])
  @@map("indent_status_history")
}

model Unit {
  id           String   @id @default(uuid())
  name         String // e.g., "kg", "meter", "piece", "liter"
  abbreviation String // e.g., "kg", "m", "pcs", "L"
  category     String? // e.g., "Weight", "Length", "Volume", "Quantity"
  isDefault    Boolean  @default(false) // Mark default/seeded units (cannot be deleted)
  isActive     Boolean  @default(true) // Allow soft deletion
  createdBy    String? // User who created this unit (null for seeded units)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaceId         String?
  workspace           Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator             WorkspaceMember?     @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  materials           Material[]
  indentDecisionItems IndentDecisionItem[]
  indentItems         IndentItem[]

  @@index([isActive])
  @@index([isDefault])
  @@index([createdBy])
  @@map("unit")
}

model Material {
  id             String   @id @default(uuid())
  name           String   @unique
  specifications String? // Optional technical specifications
  defaultUnitId  String // Default unit of measure for this material
  workspaceId    String
  isActive       Boolean  @default(true) // Allow soft deletion
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  defaultUnit         Unit                 @relation(fields: [defaultUnitId], references: [id], onDelete: Restrict)
  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vendors             Vendor[]
  indentDecisionItems IndentDecisionItem[]
  indentDecisions     IndentDecision[]
  indentItems         IndentItem[]

  @@index([workspaceId])
  @@index([isActive])
  @@index([name])
  @@map("material")
}

model Vendor {
  id            String   @id @default(uuid())
  name          String // Display name or Alias
  companyName   String? // Legal Company Name
  contactPerson String?
  contactNumber String?
  email         String?
  address       String?
  gstNumber     String?
  workspaceId   String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  materials Material[]

  @@index([workspaceId])
  @@index([name])
  @@map("vendor")
}
