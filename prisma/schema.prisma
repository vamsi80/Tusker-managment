generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id
  name          String
  surname       String?
  contactNumber String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?

  // Ownership & Membership
  workspaceOwner Workspace[]
  workspaces     WorkspaceMember[]
  accounts       Account[]
  sessions       Session[]

  // Business Actions (User owns all actions)
  createdTasks   Task[]          @relation("TaskCreator")
  assignedTasks  Task[]          @relation("TaskAssignee")
  comments       Comment[]
  reviewComments ReviewComment[]

  // Indent & Procurement Actions
  requestedIndents      IndentDetails[] @relation("IndentRequestor")
  assignedIndents       IndentDetails[] @relation("IndentAssignee")
  quantityApprovedItems IndentItem[]    @relation("QuantityApprover")
  finalApprovedItems    IndentItem[]    @relation("FinalApprover")

  // Purchase Order Actions
  createdPurchaseOrders  PurchaseOrder[]        @relation("POCreator")
  approvedPurchaseOrders PurchaseOrder[]        @relation("POApprover")
  recordedPayments       PurchaseOrderPayment[] @relation("PaymentRecorder")

  // Unit creation
  createdUnits Unit[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Workspace {
  id          String  @id @default(uuid())
  name        String
  description String?
  slug        String  @unique

  // ✅ COMPANY / LEGAL DETAILS
  legalName   String?
  gstNumber   String?
  panNumber   String?
  companyType String? // Pvt Ltd, LLP, Proprietorship
  industry    String?
  msmeNumber  String?

  // ✅ CONTACT & ADDRESS
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  country      String?
  pincode      String?

  email   String?
  phone   String?
  website String?

  ownerId          String
  inviteCode       String            @unique
  image_url        String            @default("")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  projects         Project[]
  tags             Tag[]
  owner            User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members          WorkspaceMember[]
  materials        Material[]
  procurementTasks ProcurementTask[]
  units            Unit[]
  vendors          Vendor[]
  purchaseOrders   PurchaseOrder[]
}

model WorkspaceMember {
  id            String        @id @default(uuid())
  userId        String
  workspaceId   String
  workspaceRole WorkspaceRole @default(MEMBER)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations for authorization context only
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectMembers ProjectMember[]

  @@unique([userId, workspaceId])
  @@index([workspaceId, workspaceRole])
  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, userId])
  @@index([workspaceRole])
}

model Project {
  id               String            @id @default(uuid())
  name             String
  description      String?
  slug             String            @unique
  workspaceId      String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  clint            Clints[]
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectMembers   ProjectMember[]
  tasks            Task[]
  indentDetails    IndentDetails[]
  procurementTasks ProcurementTask[]
  purchaseOrders   PurchaseOrder[]

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([slug])
}

model ProjectMember {
  id                String          @id @default(uuid())
  projectRole       ProjectRole     @default(MEMBER)
  projectId         String
  workspaceMemberId String
  hasAccess         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspaceMember   WorkspaceMember @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)
  tasks             Task[]

  @@unique([workspaceMemberId, projectId])
  @@index([projectId, projectRole])
  @@index([projectId])
  @@index([workspaceMemberId])
  @@index([projectId, workspaceMemberId])
}

model Clints {
  id                    String         @id @default(uuid())
  name                  String
  registeredCompanyName String?
  gstNumber             String?
  directorName          String?
  address               String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  projectId             String?
  clintMembers          ClintMembers[]
  project               Project?       @relation(fields: [projectId], references: [id])
}

model ClintMembers {
  id            String   @id @default(uuid())
  name          String
  email         String?
  contactNumber String?
  clintId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  clints        Clints?  @relation(fields: [clintId], references: [id], onDelete: Cascade)
}

model Tag {
  id              String    @id @default(uuid())
  name            String
  requirePurchase Boolean?  @default(false)
  workspaceId     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks           Task[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Task {
  id           String      @id @default(uuid())
  name         String
  taskSlug     String      @unique
  description  String?
  status       TaskStatus? @default(TO_DO)
  position     Int?
  parentTaskId String?
  startDate    DateTime?
  days         Int?
  tagId        String?

  // User-based fields (keeping original field names, now pointing to User)
  createdById String
  assigneeTo  String?

  // Workspace context
  workspaceId String
  projectId   String

  // Task metadata
  purchaseRequired Boolean?  @default(false)
  isPinned         Boolean   @default(false)
  pinnedAt         DateTime?
  pinnedBy         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  createdBy  User    @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignee   User?   @relation("TaskAssignee", fields: [assigneeTo], references: [id], onDelete: SetNull)
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag        Tag?    @relation(fields: [tagId], references: [id])
  parentTask Task?   @relation("Task_subTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)

  // Children
  subTasks              Task[]           @relation("Task_subTasks")
  reviewComments        ReviewComment[]
  comments              Comment[]
  indentDetails         IndentDetails[]
  procurementTask       ProcurementTask?
  Task_TaskDependency_A Task[]           @relation("TaskDependency")
  Task_TaskDependency_B Task[]           @relation("TaskDependency")
  projectMember         ProjectMember?   @relation(fields: [projectMemberId], references: [id])
  projectMemberId       String?

  @@index([parentTaskId])
  @@index([projectId])
  @@index([workspaceId])
  @@index([projectId, parentTaskId])
  @@index([projectId, status])
  @@index([status, createdAt])
  @@index([createdById])
  @@index([assigneeTo])
  @@index([isPinned])
  @@index([position])
  @@index([tagId])
}

model ReviewComment {
  id          String   @id @default(uuid())
  subTaskId   String
  authorId    String
  workspaceId String
  text        String
  attachment  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  author  User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  subTask Task @relation(fields: [subTaskId], references: [id], onDelete: Cascade)

  @@index([subTaskId, createdAt])
  @@index([authorId])
  @@index([workspaceId])
}

model Comment {
  id              String    @id @default(uuid())
  content         String
  userId          String
  taskId          String
  parentCommentId String?
  isEdited        Boolean   @default(false)
  editedAt        DateTime?
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  parentComment   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         Comment[] @relation("CommentReplies")
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([parentCommentId])
  @@index([createdAt])
  @@map("comment")
}

model ProcurementTask {
  id            String    @id @default(uuid())
  taskId        String    @unique
  projectId     String
  workspaceId   String
  createdAt     DateTime  @default(now())
  indentCreated Boolean   @default(false)
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
  @@map("procurement_task")
}

model IndentDetails {
  id   String @id @default(uuid())
  key  String @unique
  name String

  // Workspace context
  workspaceId String
  projectId   String
  taskId      String?

  // User-based fields (keeping original field names, now pointing to User)
  requestedBy String
  assignedTo  String?

  // Indent metadata
  description      String?
  expectedDelivery DateTime?
  requiresVendor   Boolean   @default(true)
  requestedAt      DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  requestor User    @relation("IndentRequestor", fields: [requestedBy], references: [id])
  assignee  User?   @relation("IndentAssignee", fields: [assignedTo], references: [id])
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?   @relation(fields: [taskId], references: [id])

  // Children
  items IndentItem[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([taskId])
  @@index([requestedBy])
  @@index([assignedTo])
  @@index([key])
  @@map("indent_details")
}

model IndentItem {
  id              String   @id @default(uuid())
  indentDetailsId String
  materialId      String
  quantity        Float
  unitId          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  estimatedPrice  Float?
  vendorId        String?

  // Approval workflow fields (keeping original field names, now pointing to User)
  status             IndentItemStatus @default(PENDING)
  quantityApproved   Boolean          @default(false)
  quantityApprovedBy String?
  quantityApprovedAt DateTime?
  finalApproved      Boolean          @default(false)
  finalApprovedBy    String?
  finalApprovedAt    DateTime?
  rejectionReason    String?

  // Relations
  indentDetails      IndentDetails       @relation(fields: [indentDetailsId], references: [id], onDelete: Cascade)
  material           Material            @relation(fields: [materialId], references: [id])
  unit               Unit?               @relation(fields: [unitId], references: [id], onDelete: Restrict)
  vendor             Vendor?             @relation(fields: [vendorId], references: [id])
  quantityApprover   User?               @relation("QuantityApprover", fields: [quantityApprovedBy], references: [id])
  finalApprover      User?               @relation("FinalApprover", fields: [finalApprovedBy], references: [id])
  purchaseOrderItems PurchaseOrderItem[]

  @@index([indentDetailsId])
  @@index([materialId])
  @@index([vendorId])
  @@index([status])
  @@index([quantityApprovedBy])
  @@index([finalApprovedBy])
  @@map("indent_item")
}

enum IndentItemStatus {
  PENDING
  QUANTITY_APPROVED
  VENDOR_PENDING
  APPROVED
  REJECTED
}

model Unit {
  id           String  @id @default(uuid())
  name         String
  abbreviation String
  category     String?
  isDefault    Boolean @default(false)
  isActive     Boolean @default(true)

  // User-based creator field (keeping original field name, now pointing to User)
  createdBy String?

  // Workspace context
  workspaceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  creator   User?      @relation(fields: [createdBy], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Children
  indentItems        IndentItem[]
  materials          Material[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([isActive])
  @@index([isDefault])
  @@index([createdBy])
  @@index([workspaceId])
  @@map("unit")
}

model Material {
  id                 String              @id @default(uuid())
  name               String              @unique
  specifications     String?
  defaultUnitId      String
  workspaceId        String
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  indentItems        IndentItem[]
  defaultUnit        Unit                @relation(fields: [defaultUnitId], references: [id])
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vendors            Vendor[]            @relation("MaterialToVendor")
  purchaseOrderItems PurchaseOrderItem[]

  @@index([workspaceId])
  @@index([isActive])
  @@index([name])
  @@map("material")
}

model Vendor {
  id             String          @id @default(uuid())
  name           String
  companyName    String?
  contactPerson  String?
  contactNumber  String?
  email          String?
  address        String?
  gstNumber      String?
  workspaceId    String
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  indentItems    IndentItem[]
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  materials      Material[]      @relation("MaterialToVendor")
  purchaseOrders PurchaseOrder[]

  @@index([workspaceId])
  @@index([name])
  @@map("vendor")
}

// ============================================================================
// PURCHASE ORDER MODULE
// ============================================================================

model PurchaseOrder {
  id       String @id @default(uuid())
  poNumber String @unique // Unique PO identifier (e.g., PO-2026-001)

  // Multi-tenant context
  workspaceId String
  vendorId    String
  projectId   String // Optional project linkage

  // Financial details
  subtotalAmount Decimal @default(0) @db.Decimal(15, 2) // Sum of all line totals (before tax)
  totalTaxAmount Decimal @default(0) @db.Decimal(15, 2) // Sum of all tax amounts
  totalAmount    Decimal @db.Decimal(15, 2) // Grand total (subtotal + tax)
  currency       String  @default("INR") // Currency code (INR, USD, etc.)

  // Delivery details
  deliveryAddressLine1 String
  deliveryAddressLine2 String?
  deliveryCity         String
  deliveryState        String
  deliveryCountry      String
  deliveryPincode      String?

  deliveryingAt      DateTime
  termsAndConditions String?  @db.Text

  // Lifecycle management
  status POStatus @default(DRAFT)

  // User actions (ownership tracking)
  createdById  String
  approvedById String?

  // Timestamps
  createdAt  DateTime  @default(now())
  approvedAt DateTime?
  updatedAt  DateTime  @updatedAt

  // Relations
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vendor     Vendor    @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  project    Project   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy  User      @relation("POCreator", fields: [createdById], references: [id])
  approvedBy User?     @relation("POApprover", fields: [approvedById], references: [id])

  // Children
  items                 PurchaseOrderItem[]
  purchaseOrderPayments PurchaseOrderPayment[]
  purchaseOrderTerms    PurchaseOrderTerm[]

  @@index([workspaceId])
  @@index([vendorId])
  @@index([projectId])
  @@index([status])
  @@index([createdById])
  @@index([approvedById])
  @@index([poNumber])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@map("purchase_order")
}

model PurchaseOrderTerm {
  id              String @id @default(uuid())
  purchaseOrderId String

  termNumber Int // 1, 2, 3, 4...
  title      String? // Optional short heading
  content    String // Full term text

  createdAt DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@unique([purchaseOrderId, termNumber])
  @@index([purchaseOrderId])
}

model PurchaseOrderItem {
  id              String @id @default(uuid())
  purchaseOrderId String

  // Material details
  materialId String
  unitId     String

  // Quantity and pricing
  orderedQuantity Decimal @db.Decimal(15, 3) // Quantity ordered
  unitPrice       Decimal @db.Decimal(15, 2) // Price per unit (before tax)

  // Tax details (Indian GST)
  sgstPercent Decimal? @db.Decimal(5, 2) // SGST percentage (e.g., 9.00 for 9%)
  cgstPercent Decimal? @db.Decimal(5, 2) // CGST percentage (e.g., 9.00 for 9%)

  // Calculated totals
  lineTotal   Decimal @db.Decimal(15, 2) // Subtotal: orderedQuantity * unitPrice (before tax)
  taxAmount   Decimal @default(0) @db.Decimal(15, 2) // Total tax: (lineTotal * (sgst + cgst) / 100)
  totalAmount Decimal @db.Decimal(15, 2) // Final total: lineTotal + taxAmount

  // Traceability (optional link to source indent)
  indentItemId String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  material      Material      @relation(fields: [materialId], references: [id], onDelete: Restrict)
  unit          Unit          @relation(fields: [unitId], references: [id], onDelete: Restrict)
  indentItem    IndentItem?   @relation(fields: [indentItemId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([materialId])
  @@index([indentItemId])
  @@map("purchase_order_item")
}

// ============================================================================
// PAYMENT TRACKING MODULE
// ============================================================================

model PurchaseOrderPayment {
  id              String @id @default(uuid())
  purchaseOrderId String

  // Payment details
  amountPaid  Decimal  @db.Decimal(15, 2) // Amount paid in this transaction
  paymentDate DateTime // Date when payment was made
  remarks     String? // Optional notes (e.g., "Advance payment", "Final settlement")

  // Workspace context (for multi-tenant isolation)
  workspaceId String

  // User tracking (accountant who recorded this payment)
  recordedById String

  // Timestamps
  createdAt DateTime @default(now()) // When this record was created
  updatedAt DateTime @updatedAt

  // Relations
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  recordedBy    User          @relation("PaymentRecorder", fields: [recordedById], references: [id])

  @@index([purchaseOrderId])
  @@index([workspaceId])
  @@index([recordedById])
  @@index([paymentDate])
  @@index([purchaseOrderId, paymentDate]) // For payment history queries
  @@map("purchase_order_payment")
}

// ============================================================================
// ENUMS
// ============================================================================

enum PaymentStatus {
  UNPAID // No payments made yet
  PARTIALLY_PAID // Some payments made, but total < PO amount
  PAID // Total payments >= PO amount
  OVERPAID // Total payments > PO amount (edge case)
}

// ============================================================================
// ENUMS
// ============================================================================

enum POStatus {
  DRAFT // PO created but not yet approved
  APPROVED // PO approved and sent to vendor
  CANCELLED // PO cancelled (before or after approval)
  CLOSED // PO fulfilled and closed
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectRole {
  LEAD
  MEMBER
  VIEWER
}

enum TaskStatus {
  TO_DO
  IN_PROGRESS
  BLOCKED
  REVIEW
  HOLD
  COMPLETED
}

enum RfqStatus {
  DRAFT
  OPEN
  CLOSED
}
