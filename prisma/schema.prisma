generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String            @id
  name           String
  surname        String?
  contactNumber  String?
  email          String            @unique
  emailVerified  Boolean           @default(false)
  image          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @default(now()) @updatedAt
  role           String?
  banned         Boolean?          @default(false)
  banReason      String?
  banExpires     DateTime?
  workspaceOwner Workspace[]
  workspaces     WorkspaceMember[]
  accounts       Account[]
  auditLogs      AuditLog[]
  comments       Comment[]
  sessions       Session[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Workspace {
  id               String            @id @default(uuid())
  name             String
  description      String?
  slug             String            @unique
  ownerId          String
  inviteCode       String            @unique
  image_url        String            @default("")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  projects         Project[]
  tags             Tag[]
  owner            User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members          WorkspaceMember[]
  materials        Material[]
  procurementTasks ProcurementTask[]
  rfqs             Rfq[]
  units            Unit[]
  vendors          Vendor[]
}

model WorkspaceMember {
  id                                                        String          @id @default(uuid())
  userId                                                    String
  workspaceId                                               String
  workspaceRole                                             WorkspaceRole   @default(MEMBER)
  createdAt                                                 DateTime        @default(now())
  updatedAt                                                 DateTime        @updatedAt
  projectMembers                                            ProjectMember[]
  reviewComments                                            ReviewComment[]
  tasks                                                     Task[]
  user                                                      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace                                                 Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  auditLogs                                                 AuditLog[]
  indent_details_indent_details_assignedToToWorkspaceMember IndentDetails[] @relation("indent_details_assignedToToWorkspaceMember")
  indentDetails                                             IndentDetails[]
  units                                                     Unit[]
  quantityApprovedItems                                     IndentItem[]    @relation("quantity_approver")
  finalApprovedItems                                        IndentItem[]    @relation("final_approver")

  @@unique([userId, workspaceId])
  @@index([workspaceId, workspaceRole])
  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, userId])
  @@index([workspaceRole])
}

model Project {
  id               String            @id @default(uuid())
  name             String
  description      String?
  slug             String            @unique
  workspaceId      String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  clint            Clints[]
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectMembers   ProjectMember[]
  tasks            Task[]
  auditLogs        AuditLog[]
  indentDetails    IndentDetails[]
  procurementTasks ProcurementTask[]

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([slug])
}

model ProjectMember {
  id                String          @id @default(uuid())
  projectRole       ProjectRole     @default(MEMBER)
  projectId         String
  workspaceMemberId String
  hasAccess         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspaceMember   WorkspaceMember @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)
  tasks             Task[]

  @@unique([workspaceMemberId, projectId])
  @@index([projectId, projectRole])
  @@index([projectId])
  @@index([workspaceMemberId])
  @@index([projectId, workspaceMemberId])
}

model Clints {
  id                    String         @id @default(uuid())
  name                  String
  registeredCompanyName String?
  gstNumber             String?
  directorName          String?
  address               String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  projectId             String?
  clintMembers          ClintMembers[]
  project               Project?       @relation(fields: [projectId], references: [id])
}

model ClintMembers {
  id            String   @id @default(uuid())
  name          String
  email         String?
  contactNumber String?
  clintId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  clints        Clints?  @relation(fields: [clintId], references: [id], onDelete: Cascade)
}

model Tag {
  id              String    @id @default(uuid())
  name            String
  requirePurchase Boolean?  @default(false)
  workspaceId     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks           Task[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Task {
  id                    String           @id @default(uuid())
  name                  String
  taskSlug              String           @unique
  description           String?
  status                TaskStatus?      @default(TO_DO)
  position              Int?
  parentTaskId          String?
  startDate             DateTime?
  days                  Int?
  tagId                 String?
  assigneeTo            String?
  createdById           String
  projectId             String
  purchaseRequired      Boolean?         @default(false)
  isPinned              Boolean          @default(false)
  pinnedAt              DateTime?
  pinnedBy              String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  reviewComments        ReviewComment[]
  assignee              ProjectMember?   @relation(fields: [assigneeTo], references: [id], onDelete: Cascade)
  createdBy             WorkspaceMember  @relation(fields: [createdById], references: [id], onDelete: Cascade)
  parentTask            Task?            @relation("Task_subTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks              Task[]           @relation("Task_subTasks")
  project               Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag                   Tag?             @relation(fields: [tagId], references: [id])
  auditLogs             AuditLog[]
  comments              Comment[]
  indentDetails         IndentDetails[]
  procurementTask       ProcurementTask?
  Task_TaskDependency_A Task[]           @relation("TaskDependency")
  Task_TaskDependency_B Task[]           @relation("TaskDependency")

  @@index([parentTaskId])
  @@index([projectId])
  @@index([projectId, parentTaskId])
  @@index([projectId, status])
  @@index([status, createdAt])
  @@index([createdById])
  @@index([assigneeTo])
  @@index([isPinned])
  @@index([position])
  @@index([tagId])
}

model ReviewComment {
  id         String          @id @default(uuid())
  subTaskId  String
  authorId   String
  text       String
  attachment Json?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  author     WorkspaceMember @relation(fields: [authorId], references: [id], onDelete: Cascade)
  subTask    Task            @relation(fields: [subTaskId], references: [id], onDelete: Cascade)

  @@index([subTaskId, createdAt])
}

model Comment {
  id              String    @id @default(uuid())
  content         String
  userId          String
  taskId          String
  parentCommentId String?
  isEdited        Boolean   @default(false)
  editedAt        DateTime?
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  parentComment   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         Comment[] @relation("CommentReplies")
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([parentCommentId])
  @@index([createdAt])
  @@map("comment")
}

model AuditLog {
  id                String          @id @default(cuid())
  operationId       String          @unique
  entityType        String
  entityId          String
  action            String
  userId            String
  workspaceMemberId String
  beforeState       Json?
  afterState        Json
  projectId         String
  taskId            String?
  timestamp         DateTime        @default(now())
  ipAddress         String?
  userAgent         String?
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task              Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceMember   WorkspaceMember @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([entityType])
  @@index([action])
  @@index([projectId])
  @@index([userId])
  @@index([timestamp])
  @@index([operationId])
  @@map("audit_log")
}

model ProcurementTask {
  id            String    @id @default(uuid())
  taskId        String    @unique
  projectId     String
  workspaceId   String
  createdAt     DateTime  @default(now())
  indentCreated Boolean   @default(false)
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
  @@map("procurement_task")
}

model IndentDetails {
  id               String           @id @default(uuid())
  key              String           @unique
  name             String
  projectId        String
  taskId           String?
  description      String?
  expectedDelivery DateTime?
  requiresVendor   Boolean          @default(true)
  requestedBy      String
  requestedAt      DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  assignedTo       String?
  assignee         WorkspaceMember? @relation("indent_details_assignedToToWorkspaceMember", fields: [assignedTo], references: [id])
  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestor        WorkspaceMember  @relation(fields: [requestedBy], references: [id])
  task             Task?            @relation(fields: [taskId], references: [id])
  items            IndentItem[]

  @@index([projectId])
  @@index([taskId])
  @@index([requestedBy])
  @@index([key])
  @@index([assignedTo])
  @@map("indent_details")
}

model IndentItem {
  id              String   @id @default(uuid())
  indentDetailsId String
  materialId      String
  quantity        Float
  unitId          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  estimatedPrice  Float?
  vendorId        String?

  // Approval workflow fields
  status             IndentItemStatus @default(PENDING)
  quantityApproved   Boolean          @default(false)
  quantityApprovedBy String?
  quantityApprovedAt DateTime?
  finalApproved      Boolean          @default(false)
  finalApprovedBy    String?
  finalApprovedAt    DateTime?
  rejectionReason    String?

  // Relations
  indentDetails    IndentDetails    @relation(fields: [indentDetailsId], references: [id], onDelete: Cascade)
  material         Material         @relation(fields: [materialId], references: [id])
  unit             Unit?            @relation(fields: [unitId], references: [id], onDelete: Restrict)
  vendor           Vendor?          @relation(fields: [vendorId], references: [id])
  quantityApprover WorkspaceMember? @relation("quantity_approver", fields: [quantityApprovedBy], references: [id])
  finalApprover    WorkspaceMember? @relation("final_approver", fields: [finalApprovedBy], references: [id])
  rfqItems         RfqItem[]

  @@index([indentDetailsId])
  @@index([materialId])
  @@index([vendorId])
  @@index([status])
  @@map("indent_item")
}

enum IndentItemStatus {
  PENDING // Initial state - awaiting quantity approval
  QUANTITY_APPROVED // Quantity approved, waiting for vendor details
  VENDOR_PENDING // Vendor added, waiting for final approval
  APPROVED // Fully approved
  REJECTED // Rejected by admin
}

model Unit {
  id           String           @id @default(uuid())
  name         String
  abbreviation String
  category     String?
  isDefault    Boolean          @default(false)
  isActive     Boolean          @default(true)
  createdBy    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  workspaceId  String?
  indentItems  IndentItem[]
  materials    Material[]
  creator      WorkspaceMember? @relation(fields: [createdBy], references: [id])
  workspace    Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([isDefault])
  @@index([createdBy])
  @@map("unit")
}

model Material {
  id             String       @id @default(uuid())
  name           String       @unique
  specifications String?
  defaultUnitId  String
  workspaceId    String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  indentItems    IndentItem[]
  defaultUnit    Unit         @relation(fields: [defaultUnitId], references: [id])
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vendors        Vendor[]     @relation("MaterialToVendor")

  @@index([workspaceId])
  @@index([isActive])
  @@index([name])
  @@map("material")
}

model Vendor {
  id            String       @id @default(uuid())
  name          String
  companyName   String?
  contactPerson String?
  contactNumber String?
  email         String?
  address       String?
  gstNumber     String?
  workspaceId   String
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  indentItems   IndentItem[]
  quotations    Quotation[]
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  materials     Material[]   @relation("MaterialToVendor")
  rfqs          Rfq[]        @relation("RfqToVendor")

  @@index([workspaceId])
  @@index([name])
  @@map("vendor")
}

model Rfq {
  id          String      @id @default(uuid())
  key         String      @unique
  workspaceId String
  status      RfqStatus   @default(DRAFT)
  deadline    DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  quotations  Quotation[]
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items       RfqItem[]
  vendors     Vendor[]    @relation("RfqToVendor")

  @@index([workspaceId])
  @@map("rfq")
}

model RfqItem {
  id             String          @id @default(uuid())
  rfqId          String
  indentItemId   String
  quantity       Float
  quotationItems QuotationItem[]
  indentItem     IndentItem      @relation(fields: [indentItemId], references: [id])
  rfq            Rfq             @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
  @@index([indentItemId])
  @@map("rfq_item")
}

model Quotation {
  id             String          @id @default(uuid())
  rfqId          String
  vendorId       String
  quoteReference String?
  totalAmount    Float?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  rfq            Rfq             @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendor         Vendor          @relation(fields: [vendorId], references: [id])
  items          QuotationItem[]

  @@unique([rfqId, vendorId])
  @@index([rfqId])
  @@index([vendorId])
  @@map("quotation")
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  rfqItemId   String
  unitPrice   Float
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  rfqItem     RfqItem   @relation(fields: [rfqItemId], references: [id])

  @@index([quotationId])
  @@index([rfqItemId])
  @@map("quotation_item")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectRole {
  LEAD
  MEMBER
  VIEWER
}

enum TaskStatus {
  TO_DO
  IN_PROGRESS
  BLOCKED
  REVIEW
  HOLD
  COMPLETED
}

enum RfqStatus {
  DRAFT
  OPEN
  CLOSED
}

enum IndentStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}
